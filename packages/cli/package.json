{
  "name": "@anvil/cli",
  "version": "0.1.0",
  "description": "The anvil CLI and the shared engine that drives every generated tool CLI.",
  "type": "module",
  "engines": {
    "node": ">=22.17"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "anvil": "./dist/bin-anvil.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/cli/src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anvil/air": "workspace:*",
    "@anvil/certification": "workspace:*",
    "@anvil/compiler": "workspace:*",
    "@anvil/generators": "workspace:*",
    "@anvil/harness": "workspace:*",
    "@anvil/refinement": "workspace:*",
    "@anvil/runtime": "workspace:*",
    "@anvil/targets": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "fflate": "^0.8.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
