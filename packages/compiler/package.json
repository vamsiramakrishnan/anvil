{
  "name": "@anvil/compiler",
  "version": "0.1.0",
  "description": "Anvil compiler loop — parse, normalize, enrich, and validate specs into AIR.",
  "type": "module",
  "engines": {
    "node": ">=22.17"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/compiler/src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anvil/air": "workspace:*",
    "@scalar/openapi-parser": "^0.28.8",
    "fast-xml-parser": "^5.9.3",
    "fflate": "^0.8.3",
    "graphql": "^17.0.2",
    "protobufjs": "^8.7.0",
    "swagger2openapi": "^7.0.8",
    "yaml": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/swagger2openapi": "^7.0.4",
    "fast-check": "^4.9.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
