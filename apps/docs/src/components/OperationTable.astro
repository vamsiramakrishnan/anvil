---
// Renders the REAL compiled operation catalog of examples/payments. The JSON it
// imports is generated by `node scripts/gen-docs-data.mjs` from an actual
// compile, and packages/generators/src/docs-data.test.ts fails whenever this
// data drifts from what the compiler would produce today.
import catalog from "../data/payments-catalog.json";
import RiskBadge from "./RiskBadge.astro";

const ops = catalog.operations;

const postureFlags = (op: (typeof ops)[number]) => {
  const flags: string[] = [];
  if (op.humanApproval) flags.push("human approval");
  else if (op.confirmationRequired) flags.push("confirm required");
  if (op.idempotency === "required") flags.push("idempotency key");
  if (op.retrySafe) flags.push("retry-safe");
  return flags;
};
---

<div class="op-scroll">
  <table class="op-table">
    <thead>
      <tr>
        <th>Operation</th>
        <th>CLI command</th>
        <th>MCP tool</th>
        <th>Effect</th>
        <th>Risk</th>
        <th>Safety posture</th>
        <th>State</th>
      </tr>
    </thead>
    <tbody>
      {
        ops.map((op) => (
          <tr>
            <td class="op-id">
              <span class="mono">{op.id}</span>
              <span class="op-name">{op.displayName}</span>
            </td>
            <td>
              <code>{op.cli}</code>
            </td>
            <td>
              <code>{op.mcpTool}</code>
            </td>
            <td class="mono-cell">{op.effect}</td>
            <td>
              <RiskBadge risk={op.risk} effect={op.effect} reversible={op.reversible} />
            </td>
            <td>
              <span class="flags">
                {postureFlags(op).map((f) => (
                  <span class="flag">{f}</span>
                ))}
              </span>
            </td>
            <td>
              <span class={op.state === "approved" ? "state state-approved" : "state state-review"}>
                {op.state === "approved" ? "approved" : "review required"}
              </span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .op-scroll {
    overflow-x: auto;
    border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    border-radius: 6px;
  }
  .op-table {
    width: 100%;
    margin: 0;
    border-collapse: collapse;
    font-size: var(--sl-text-sm);
  }
  .op-table th {
    font-family: var(--sl-font-system-mono, monospace);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: left;
    color: var(--sl-color-gray-3);
    border-bottom: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    padding: 0.5rem 0.75rem;
    white-space: nowrap;
  }
  .op-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    vertical-align: top;
  }
  .op-table tbody tr:last-child td {
    border-bottom: none;
  }
  .op-table code {
    white-space: nowrap;
  }
  .op-id {
    min-width: 12rem;
  }
  .mono,
  .mono-cell {
    font-family: var(--sl-font-system-mono, monospace);
    font-size: var(--sl-text-xs);
  }
  .op-id .mono {
    display: block;
    font-weight: 600;
  }
  .op-name {
    display: block;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    margin-top: 0.15rem;
  }
  .flags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    max-width: 16rem;
  }
  .flag {
    font-family: var(--sl-font-system-mono, monospace);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0.05rem 0.4rem;
    border: 1px solid var(--sl-color-hairline, var(--sl-color-gray-5));
    border-radius: 3px;
    color: var(--sl-color-gray-2);
  }
  .state {
    font-family: var(--sl-font-system-mono, monospace);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }
  .state-approved {
    color: var(--ge-status-passed-text);
    border-color: color-mix(in srgb, var(--ge-status-passed) 45%, transparent);
    background: color-mix(in srgb, var(--ge-status-passed) 12%, transparent);
  }
  .state-review {
    color: var(--ge-status-warning-text);
    border-color: color-mix(in srgb, var(--ge-status-warning) 45%, transparent);
    background: color-mix(in srgb, var(--ge-status-warning) 12%, transparent);
    border-style: dashed;
  }
</style>
