{
  "name": "@anvil/docs",
  "type": "module",
  "private": true,
  "description": "Anvil's documentation website — Astro + Starlight, content synced from the repo's canonical docs/ and skills/ (this app is presentation only).",
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "sync:check": "node scripts/sync-content.mjs --dry-run",
    "dev": "node scripts/sync-content.mjs && astro dev",
    "build": "node scripts/sync-content.mjs && astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.34",
    "@fontsource/hanken-grotesk": "^5",
    "@fontsource/jetbrains-mono": "^5",
    "astro": "^5",
    "sharp": "^0.33"
  }
}
